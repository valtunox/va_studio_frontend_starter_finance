# API Configuration
# Backend runs on port 5112
VITE_API_URL=http://localhost:5112/api/v1

# Authentication
# Auth endpoints on the backend
VITE_AUTH_API_URL=http://localhost:5112/api/v1/auth

# Environment
# Values: production, staging, development
VITE_ENV=development

# Feature Flags (CUSTOMIZE: Add your feature toggles)
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_BETA_FEATURES=false

# Debugging
# Set to 'true' to enable detailed logging
VITE_DEBUG_API=false
VITE_DEBUG_STORAGE=false

# App Metadata
VITE_APP_NAME=YourApp
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Modern React template with AI in mind
